{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8080/v1",
        "timeout": 600000,
        "chunkTimeout": 600000
      },
      "models": {
        "Qwen3.6-35B-A3B-UD-Q4_K_M.gguf": {
          "name": "Qwen 3.6 35B A3B TurboQuant Local",
          "limit": {
            "context": 131072,
            "output": 16384
          }
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--browser", "chrome", "--viewport-size", "1920x1080"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    }
  },
  "agent": {
    "general": {
      "disable": true,
      "hidden": true
    },
    "explore": {
      "disable": true,
      "hidden": true
    },
    "plan": {
      "tools": {
        "playwright*": true,
        "context7*": true
      }
    },
    "build": {
      "tools": {
        "playwright*": true,
        "context7*": true
      }
    },
    "explorer": {
      "tools": {
        "playwright*": true,
        "context7*": true
      }
    },
    "worker": {
      "tools": {
        "playwright*": true,
        "context7*": true
      }
    },
    "tester": {
      "tools": {
        "playwright*": true,
        "context7*": true
      }
    },
    "debugger": {
      "tools": {
        "playwright*": true,
        "context7*": true
      }
    },
    "reviewer": {
      "tools": {
        "playwright*": true,
        "context7*": true
      }
    }
  }
}
