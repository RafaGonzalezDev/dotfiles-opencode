{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--browser", "chrome", "--viewport-size", "1920x1080"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    }
  },
  "agent": {
    "general": {
      "disable": true,
      "hidden": true
    },
    "explore": {
      "disable": true,
      "hidden": true
    },
    "plan": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "atlassian*": true
      }
    },
    "build": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "atlassian*": true
      }
    },
    "explorer": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "atlassian*": true
      }
    },
    "worker": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "atlassian*": true
      }
    },
    "tester": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "atlassian*": true
      }
    },
    "debugger": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "atlassian*": true
      }
    },
    "reviewer": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "atlassian*": true
      }
    }
  }
}
