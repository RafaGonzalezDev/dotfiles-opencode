{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--browser", "chrome", "--viewport-size", "1920x1080"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    }
  },
  "agent": {
    "general": {
      "disable": true,
      "hidden": true
    },
    "plan": {
      "disable": true,
      "hidden": true
    },
    "build": {
      "disable": true,
      "hidden": true
    },
    "explore": {
      "disable": true,
      "hidden": true
    },
    "learning": {
      "tools": {
        "playwright*": true,
        "context7*": true
      }
    },
    "explorer": {
      "tools": {
        "playwright*": true,
        "context7*": true
      }
    },
    "researcher": {
      "tools": {
        "playwright*": true,
        "context7*": true
      }
    }
  }
}
