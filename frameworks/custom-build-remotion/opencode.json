{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--browser", "chrome", "--viewport-size", "1920x1080"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "remotion-documentation": {
      "type": "local",
      "command": ["npx", "-y", "@remotion/mcp@latest"],
      "enabled": true
    }
  },
  "agent": {
    "plan": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "remotion-documentation*": true
      }
    },
    "build": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "remotion-documentation*": true
      }
    },
    "explore": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "remotion-documentation*": true
      }
    },
    "general": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "remotion-documentation*": true
      }
    },
    "testing": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "remotion-documentation*": true
      }
    },
    "debug": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "remotion-documentation*": true
      }
    },
    "review": {
      "tools": {
        "playwright*": true,
        "context7*": true,
        "remotion-documentation*": true
      }
    }
  }
}
