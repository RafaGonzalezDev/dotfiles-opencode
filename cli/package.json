{
  "name": "opencode-setup",
  "version": "1.0.0",
  "description": "Interactive CLI for setting up OpenCode environment",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "opencode-setup": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
