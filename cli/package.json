  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "ink": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-select-input": "^6.0.0",
    "ink-link": "^5.0.0",
    "ink-confirm-input": "^2.0.0",
    "execa": "^9.5.2",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.0"
  }
}
